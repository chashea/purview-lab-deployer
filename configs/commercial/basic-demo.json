    "dlp": {
      "enabled": true,
      "policies": [
        {
          "name": "US PII Protection",
          "locations": [
            "Exchange",
            "SharePoint",
            "OneDrive",
            "Teams"
          ],
          "rules": [
            {
              "name": "Detect Social Security Numbers",
              "sensitiveInfoTypes": [
                "U.S. Social Security Number (SSN)"
              ],
              "minCount": 5,
              "enforcement": {
                "action": "block",
                "userNotification": {
                  "enabled": true,
                  "message": "This content matches a DLP policy. Contact your compliance team if you believe this is in error."
                },
                "alert": {
                  "enabled": true,
                  "severity": "medium"
                }
              }
            },
            {
              "name": "Detect Credit Card Numbers",
              "sensitiveInfoTypes": [
                "Credit Card Number"
              ],
              "minCount": 5,
              "enforcement": {
                "action": "block",
                "userNotification": {
                  "enabled": true,
                  "message": "This content matches a DLP policy. Contact your compliance team if you believe this is in error."
                },
                "alert": {
                  "enabled": true,
                  "severity": "medium"
                }
              }
            }
          ]
        },
        {
          "name": "Financial Data Protection",
          "locations": [
            "Exchange",
            "SharePoint",
            "OneDrive",
            "Teams"
          ],
          "appliesToGroups": [
            "PVLab-Finance-Team"
          ],
          "rules": [
            {
              "name": "Detect Bank Account Numbers",
              "sensitiveInfoTypes": [
                "U.S. Bank Account Number"
              ],
              "minCount": 1,
              "enforcement": {
                "action": "block",
                "userNotification": {
                  "enabled": true,
                  "message": "This content matches a DLP policy. Contact your compliance team if you believe this is in error."
                },
                "alert": {
                  "enabled": true,
                  "severity": "medium"
                }
              }
            },
            {
              "name": "Detect Credit Cards in Financial Comms",
              "sensitiveInfoTypes": [
                "Credit Card Number"
              ],
              "minCount": 1,
              "enforcement": {
                "action": "block",
                "userNotification": {
                  "enabled": true,
                  "message": "This content matches a DLP policy. Contact your compliance team if you believe this is in error."
                },
                "alert": {
                  "enabled": true,
                  "severity": "medium"
                }
              }
            }
          ]
        },
        {
          "name": "HR Case Data Protection",
          "locations": [
            "Exchange",
            "SharePoint",
            "OneDrive",
            "Teams"
          ],
          "appliesToGroups": [
            "PVLab-Legal-Team"
          ],
          "rules": [
            {
              "name": "Detect SSNs in HR Case Files",
              "sensitiveInfoTypes": [
                "U.S. Social Security Number (SSN)"
              ],
              "minCount": 1,
              "enforcement": {
                "action": "block",
                "userNotification": {
                  "enabled": true,
                  "message": "This content matches a DLP policy. Contact your compliance team if you believe this is in error."
                },
                "alert": {
                  "enabled": true,
                  "severity": "medium"
                }
              }
            },
            {
              "name": "Detect Bank Account Data in HR Cases",
              "sensitiveInfoTypes": [
                "U.S. Bank Account Number"
              ],
              "minCount": 1,
              "enforcement": {
                "action": "block",
                "userNotification": {
                  "enabled": true,
                  "message": "This content matches a DLP policy. Contact your compliance team if you believe this is in error."
                },
                "alert": {
                  "enabled": true,
                  "severity": "medium"
                }
              }
            }
          ]
        },
        {
          "name": "Workplace Health Record Protection",
          "locations": [
            "Exchange",
            "SharePoint",
            "OneDrive",
            "Teams"
          ],
          "rules": [
            {
              "name": "Detect Medical Terms in Workplace Health Records",
              "sensitiveInfoTypes": [
                "All Medical Terms And Conditions"
              ],
              "minCount": 1,
              "enforcement": {
                "action": "block",
                "userNotification": {
                  "enabled": true,
                  "message": "This content matches a DLP policy. Contact your compliance team if you believe this is in error."
                },
                "alert": {
                  "enabled": true,
                  "severity": "medium"
                }
              }
            },
            {
              "name": "Detect SSNs in Workplace Health Records",
              "sensitiveInfoTypes": [
                "U.S. Social Security Number (SSN)"
              ],
              "minCount": 1,
              "enforcement": {
                "action": "block",
                "userNotification": {
                  "enabled": true,
                  "message": "This content matches a DLP policy. Contact your compliance team if you believe this is in error."
                },
                "alert": {
                  "enabled": true,
                  "severity": "medium"
                }
              }
            }
          ]
        },
        {
          "name": "Confidential Label Egress Block",
          "locations": [
            "Exchange",
            "SharePoint",
            "OneDrive",
            "Teams"
          ],
          "rules": [
            {
              "name": "Block external sharing of Highly Confidential Regulated-Data",
              "labels": [
                "Highly Confidential\\Regulated-Data"
              ],
              "enforcement": {
                "action": "block",
                "userNotification": {
                  "enabled": true,
                  "message": "Content labeled Highly Confidential / Regulated-Data cannot be shared externally. Contact compliance for an exception."
                },
                "alert": {
                  "enabled": true,
                  "severity": "high"
                }
              }
            }
          ]
        }
      ]
    },
    "sensitivityLabels": {
      "enabled": true,
      "labels": [
        {
          "name": "Confidential",
          "tooltip": "Data that requires protection and is intended for internal use only",
          "color": "#0078D4",
          "sublabels": [
            {
              "name": "Internal",
              "tooltip": "Internal-use only - all employees",
              "encryption": false,
              "contentMarking": {
                "headerText": "CONFIDENTIAL - Internal",
                "footerText": "Do not share outside the organization"
              }
            },
            {
              "name": "Recipients-Only",
              "tooltip": "Encrypted - accessible only to named recipients",
              "encryption": true,
              "contentMarking": {
                "headerText": "CONFIDENTIAL - Recipients Only",
                "footerText": "Encrypted and restricted to named recipients"
              }
            },
            {
              "name": "Anyone-No-Forwarding",
              "tooltip": "Encrypted - recipients can read but cannot forward, copy, or print",
              "encryption": true,
              "contentMarking": {
                "headerText": "CONFIDENTIAL - Do Not Forward",
                "footerText": "Forwarding, copying, and printing are disabled"
              }
            },
            {
              "name": "Regulated-Data",
              "tooltip": "Encrypted - regulated data (PII, PCI, financial). Block external egress.",
              "encryption": true,
              "contentMarking": {
                "headerText": "CONFIDENTIAL - Regulated Data",
                "footerText": "Subject to regulatory protection (PII / PCI / financial). Restricted distribution."
              }
            },
            {
              "name": "Vertical-Specific",
              "tooltip": "Encrypted - vertical-specific scoping (e.g., medical, HR). Restricted to authorized teams.",
              "encryption": true,
              "contentMarking": {
                "headerText": "CONFIDENTIAL - Vertical-Specific",
                "footerText": "Restricted to authorized vertical/business unit"
              }
            }
          ]
        },
        {
          "name": "Highly Confidential",
          "tooltip": "Highly sensitive data requiring strict access controls and encryption",
          "color": "#D13438",
          "sublabels": [
            {
              "name": "Internal",
              "tooltip": "Encrypted - highly sensitive internal-only content",
              "encryption": true,
              "contentMarking": {
                "headerText": "HIGHLY CONFIDENTIAL - Internal",
                "footerText": "Encrypted - do not share outside the organization"
              }
            },
            {
              "name": "Recipients-Only",
              "tooltip": "Encrypted - accessible only to named recipients",
              "encryption": true,
              "contentMarking": {
                "headerText": "HIGHLY CONFIDENTIAL - Recipients Only",
                "footerText": "Encrypted and restricted to named recipients"
              }
            },
            {
              "name": "Anyone-No-Forwarding",
              "tooltip": "Encrypted - recipients can read but cannot forward, copy, or print",
              "encryption": true,
              "contentMarking": {
                "headerText": "HIGHLY CONFIDENTIAL - Do Not Forward",
                "footerText": "Forwarding, copying, and printing are disabled"
              }
            },
            {
              "name": "Regulated-Data",
              "tooltip": "Encrypted - regulated data (PII, PCI, PHI, financial). Block all external egress.",
              "encryption": true,
              "contentMarking": {
                "headerText": "HIGHLY CONFIDENTIAL - Regulated Data",
                "footerText": "Subject to regulatory protection. External egress blocked by DLP."
              }
            },
            {
              "name": "Vertical-Specific",
              "tooltip": "Encrypted - vertical-specific scoping (e.g., medical, executive, board-only).",
              "encryption": true,
              "contentMarking": {
                "headerText": "HIGHLY CONFIDENTIAL - Vertical-Specific",
                "footerText": "Restricted to authorized vertical/business unit"
              }
            }
          ]
        }
      ],
      "autoLabelPolicies": [
        {
          "name": "Auto-label SSN as Highly Confidential Regulated-Data",
          "labelName": "Highly Confidential\\Regulated-Data",
          "sensitiveInfoTypes": [
            "U.S. Social Security Number (SSN)"
          ],
          "locations": [
            "Exchange",
            "SharePoint",
            "OneDrive"
          ]
        },
        {
          "name": "Auto-label Credit Card as Highly Confidential Regulated-Data",
          "labelName": "Highly Confidential\\Regulated-Data",
          "sensitiveInfoTypes": [
            "Credit Card Number"
          ],
          "locations": [
            "Exchange",
            "SharePoint",
            "OneDrive"
          ]
        },
        {
          "name": "Auto-label Internal-Corp Identifiers as Confidential Internal",
          "labelName": "Confidential\\Internal",
          "sensitiveInfoTypes": [
            "U.S. Employer Identification Number (EIN)",
            "International Banking Account Number (IBAN)",
            "SWIFT Code"
          ],
          "locations": [
            "Exchange",
            "SharePoint",
            "OneDrive"
          ]
        }
      ]
