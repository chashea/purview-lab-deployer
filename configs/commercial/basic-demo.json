    "retention": {
      "enabled": true,
      "policies": [
        {
          "name": "Financial Records Retention",
          "retentionDays": 2555,
          "retentionAction": "retainAndDelete",
          "locations": [
            "Exchange",
            "SharePoint"
          ]
        },
        {
          "name": "Legal Hold Policy",
          "retentionDays": 365,
          "retentionAction": "retainOnly",
          "locations": [
            "Exchange",
            "OneDrive"
          ]
        }
      ]
    },
    "eDiscovery": {
      "enabled": true,
      "cases": [
        {
          "name": "Data-Breach-Investigation",
          "description": "Investigation into potential data breach involving unauthorized access to confidential financial records and PII",
          "custodians": [
            "mchen@MngEnvMCAP648165.onmicrosoft.com",
            "jblake@MngEnvMCAP648165.onmicrosoft.com",
            "pnair@MngEnvMCAP648165.onmicrosoft.com",
            "msullivan@MngEnvMCAP648165.onmicrosoft.com"
          ],
          "holdQuery": "(subject:\"confidential\" OR subject:\"classified\" OR body:\"breach\" OR body:\"unauthorized\") AND received>=2025-01-01",
          "searchQuery": "breach OR incident",
          "searches": [
            {
              "name": "Financial-Records",
              "contentQuery": "subject:\"financial\" OR body:\"wire transfer\" OR body:\"account number\"",
              "dataSourceScopes": "allCaseCustodians"
            },
            {
              "name": "PII-Exfil",
              "contentQuery": "body:\"social security\" OR body:\"SSN\" OR body:\"credit card\"",
              "dataSourceScopes": "allCaseCustodians"
            },
            {
              "name": "Suspicious-Activity",
              "contentQuery": "subject:\"suspicious\" OR body:\"unauthorized access\" OR body:\"breach\"",
              "dataSourceScopes": "allCaseCustodians"
            }
          ],
          "reviewSets": [
            {
              "name": "Financial-Review",
              "sourceSearch": "Financial-Records"
            },
            {
              "name": "PII-Review",
              "sourceSearch": "PII-Exfil"
            },
            {
              "name": "Incident-Review",
              "sourceSearch": "Suspicious-Activity"
            }
          ]
        },
        {
          "name": "HR-Investigation",
          "description": "HR investigation into workplace conduct allegations including harassment, inappropriate communications, and policy violations.",
          "custodians": [
            "rtorres@MngEnvMCAP648165.onmicrosoft.com",
            "pnair@MngEnvMCAP648165.onmicrosoft.com",
            "nbrooks@MngEnvMCAP648165.onmicrosoft.com",
            "msullivan@MngEnvMCAP648165.onmicrosoft.com"
          ],
          "holdQuery": "(subject:\"complaint\" OR subject:\"investigation\" OR body:\"harassment\" OR body:\"misconduct\" OR body:\"hostile\") AND received>=2025-01-01",
          "searches": [
            {
              "name": "Harassment-Complaints",
              "contentQuery": "body:\"harassment\" OR body:\"hostile\" OR body:\"inappropriate behavior\"",
              "dataSourceScopes": "allCaseCustodians"
            },
            {
              "name": "Termination-Records",
              "contentQuery": "subject:\"termination\" OR body:\"severance\" OR body:\"departure\" OR body:\"resignation\"",
              "dataSourceScopes": "allCaseCustodians"
            },
            {
              "name": "Background-Check-PII",
              "contentQuery": "body:\"social security\" OR body:\"SSN\" OR body:\"date of birth\" OR body:\"background check\"",
              "dataSourceScopes": "allCaseCustodians"
            }
          ],
          "reviewSets": [
            {
              "name": "Conduct-Review",
              "sourceSearch": "Harassment-Complaints"
            },
            {
              "name": "Separation-Review",
              "sourceSearch": "Termination-Records"
            },
            {
              "name": "PII-Review",
              "sourceSearch": "Background-Check-PII"
            }
          ]
        }
      ]
    },
