    "eDiscovery": {
      "enabled": true,
      "cases": [
        {
          "name": "Shadow-AI-Incident-Review",
          "description": "Investigation into potential sensitive data exposure through unapproved AI tool usage.",
          "custodians": [
            "etran",
            "lramirez",
            "pdesai"
          ],
          "holdQuery": "\"AI\" OR \"copilot\" OR \"chatbot\" OR \"prompt\"",
          "searchQuery": "\"public AI\" OR \"external AI\" OR \"paste\" OR \"upload\"",
          "searches": [
            {
              "name": "AI Tool Activity Search",
              "contentQuery": "\"public AI\" OR \"external AI\" OR \"paste\" OR \"upload\"",
              "dataSourceScopes": "allCaseCustodians"
            },
            {
              "name": "Sensitive Data in AI Prompts",
              "contentQuery": "\"SSN\" OR \"social security\" OR \"credit card\" OR \"api key\" OR \"password\"",
              "dataSourceScopes": "allCaseCustodians"
            }
          ],
          "reviewSets": [
            {
              "name": "Shadow AI Evidence Collection",
              "description": "Evidence of sensitive data exposure through unapproved AI tool usage",
              "sourceSearch": "AI Tool Activity Search"
            }
          ]
        },
        {
          "name": "AI-Data-Exfiltration-Investigation",
          "description": "Investigation into confirmed data exfiltration via AI tools including prompt history and file upload evidence.",
          "custodians": [
            "aharper",
            "vcho"
          ],
          "holdQuery": "\"upload\" OR \"paste\" OR \"AI\" OR \"chatgpt\" OR \"copilot\"",
          "searchQuery": "\"SSN\" OR \"credit card\" OR \"bank account\" OR \"confidential\" OR \"api key\"",
          "searches": [
            {
              "name": "Exfiltrated Data Search",
              "contentQuery": "\"SSN\" OR \"credit card\" OR \"bank account\" OR \"confidential\" OR \"api key\"",
              "dataSourceScopes": "allCaseCustodians"
            },
            {
              "name": "File Upload Evidence",
              "contentQuery": "\"upload\" OR \"paste\" OR \"chatgpt\" OR \"claude\" OR \"gemini\" OR \"external AI\"",
              "dataSourceScopes": "allCaseCustodians"
            }
          ],
          "reviewSets": [
            {
              "name": "Data Exfiltration Evidence",
              "description": "Evidence of sensitive data exfiltration via AI tools including file uploads and prompt history",
              "sourceSearch": "Exfiltrated Data Search"
            }
          ]
        },
        {
          "name": "Prompt-Injection-Investigation",
          "description": "Investigation into prompt injection or jailbreak attempts targeting enterprise AI services.",
          "custodians": [
            "etran",
            "pdesai"
          ],
          "holdQuery": "\"jailbreak\" OR \"ignore instructions\" OR \"bypass\" OR \"prompt injection\"",
          "searchQuery": "\"ignore previous\" OR \"act as\" OR \"pretend\" OR \"override\" OR \"system prompt\"",
          "searches": [
            {
              "name": "Prompt Injection Attempts",
              "contentQuery": "\"ignore previous\" OR \"act as\" OR \"pretend\" OR \"override\" OR \"system prompt\" OR \"jailbreak\"",
              "dataSourceScopes": "allCaseCustodians"
            }
          ],
          "reviewSets": [
            {
              "name": "Prompt Injection Evidence",
              "description": "Evidence of prompt injection or jailbreak attempts targeting enterprise AI services",
              "sourceSearch": "Prompt Injection Attempts"
            }
          ]
        }
      ]
    },
