          "labels": [
            "PVShadowAI-Highly-Confidential-All-Employees",
            "PVShadowAI-Highly-Confidential-AI-Internal-Use",
            "PVShadowAI-Highly-Confidential-AI-Restricted-Recipients",
            "PVShadowAI-Highly-Confidential-AI-Blocked-from-External-Tools",
            "PVShadowAI-Highly-Confidential-AI-Regulated-Data",
            "PVShadowAI-Confidential-AI-Blocked-from-External-Tools",
            "PVShadowAI-Confidential-AI-Regulated-Data"
          ],
          "rules": [
            {
              "name": "Block Copilot from Labeled Content",
              "labels": [
                "PVShadowAI-Highly-Confidential-All-Employees",
                "PVShadowAI-Highly-Confidential-AI-Internal-Use",
                "PVShadowAI-Highly-Confidential-AI-Restricted-Recipients",
                "PVShadowAI-Highly-Confidential-AI-Blocked-from-External-Tools",
                "PVShadowAI-Highly-Confidential-AI-Regulated-Data",
                "PVShadowAI-Confidential-AI-Blocked-from-External-Tools",
                "PVShadowAI-Confidential-AI-Regulated-Data"
              ],
              "enforcement": {
                "action": "block",
                "userNotification": {
                  "enabled": true,
                  "message": "Copilot cannot process this content. It has a sensitivity label that restricts AI processing. Remove or downgrade the label if Copilot access is required."
