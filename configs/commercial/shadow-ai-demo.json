    "dlp": {
      "enabled": true,
      "simulationMode": true,
      "policies": [
        {
          "name": "Shadow AI - Endpoint Protection",
          "policyMode": "endpointProtection",
          "locations": [
            "Devices"
          ],
          "endpointDlpBrowserRestrictions": {
            "blockedUrls": [
              "chat.openai.com",
              "chatgpt.com",
              "claude.ai",
              "gemini.google.com",
              "bard.google.com",
              "copilot.microsoft.com",
              "poe.com",
              "perplexity.ai",
              "huggingface.co/chat"
            ]
          },
          "rules": [
            {
              "name": "Endpoint AI Block - Elevated Risk",
              "sensitiveInfoTypes": [
                "U.S. Social Security Number (SSN)",
                "Credit Card Number",
                "U.S. Bank Account Number",
                "All Medical Terms And Conditions"
              ],
              "minCount": 1,
              "insiderRiskLevel": "Elevated",
              "enforcement": {
                "action": "block",
                "userNotification": {
                  "enabled": true,
                  "message": "Sensitive data detected. Uploading or pasting to external AI tools is blocked. Use Microsoft Copilot for AI-assisted tasks with organizational data protection."
                },
                "alert": {
                  "enabled": true,
                  "severity": "high"
                },
                "incidentReport": {
                  "enabled": true,
                  "severity": "high"
                }
              }
            },
            {
              "name": "Endpoint AI Warn - Moderate Risk",
              "sensitiveInfoTypes": [
                "U.S. Social Security Number (SSN)",
                "Credit Card Number",
                "U.S. Bank Account Number",
                "All Medical Terms And Conditions"
              ],
              "minCount": 1,
              "insiderRiskLevel": "Moderate",
              "enforcement": {
                "action": "allowWithJustification",
                "userNotification": {
                  "enabled": true,
                  "message": "Sensitive data detected. Provide a business justification to continue sharing with this AI tool, or use Microsoft Copilot instead."
                },
                "alert": {
                  "enabled": true,
                  "severity": "medium"
                }
              }
            },
            {
              "name": "Endpoint AI Audit - Minor Risk",
              "sensitiveInfoTypes": [
                "U.S. Social Security Number (SSN)",
                "Credit Card Number",
                "U.S. Bank Account Number",
                "All Medical Terms And Conditions"
