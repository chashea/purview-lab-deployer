        {
          "displayName": "PVMed-Leadership",
          "members": [
            "spatel",
            "rfeng"
          ]
        }
      ]
    },
    "dlp": {
      "enabled": true,
      "policies": [
        {
          "name": "HIPAA PHI Protection",
          "locations": [
            "Exchange",
            "SharePoint",
            "OneDrive"
          ],
          "rules": [
            {
              "name": "Detect DEA Numbers",
              "sensitiveInfoTypes": [
                "Drug Enforcement Agency (DEA) Number"
              ],
              "minCount": 1
            },
            {
              "name": "Detect Health Insurance Claim Numbers",
              "sensitiveInfoTypes": [
                "U.S. Health Insurance Claim Number (HICN)"
              ],
              "minCount": 1
            }
          ]
        },
        {
          "name": "Patient Data Protection",
          "locations": [
            "Exchange",
            "SharePoint",
            "Teams"
          ],
          "rules": [
            {
              "name": "Detect SSNs in Medical Context",
              "sensitiveInfoTypes": [
                "U.S. Social Security Number (SSN)"
              ],
              "minCount": 1
            },
            {
              "name": "Detect Medical Terms with PII",
              "sensitiveInfoTypes": [
                "All Medical Terms And Conditions"
              ],
              "minCount": 1
            }
          ]
        },
        {
          "name": "Clinical Staff Escalation Protection",
          "locations": [
            "Exchange",
            "SharePoint",
            "Teams"
          ],
          "rules": [
            {
              "name": "Detect DEA in Clinical Escalations",
              "sensitiveInfoTypes": [
                "Drug Enforcement Agency (DEA) Number"
              ],
              "minCount": 1
            },
            {
              "name": "Detect HICN in Clinical Escalations",
              "sensitiveInfoTypes": [
                "U.S. Health Insurance Claim Number (HICN)"
              ],
              "minCount": 1
            }
          ]
        },
        {
          "name": "HR Medical Leave Data Protection",
          "locations": [
            "Exchange",
            "SharePoint",
            "OneDrive"
          ],
          "rules": [
            {
              "name": "Detect SSNs in Leave Documentation",
              "sensitiveInfoTypes": [
                "U.S. Social Security Number (SSN)"
              ],
              "minCount": 1
            },
            {
              "name": "Detect Medical Terms in Leave Documentation",
              "sensitiveInfoTypes": [
                "All Medical Terms And Conditions"
              ],
              "minCount": 1
            }
          ]
        }
      ]
    },
    "sensitivityLabels": {
      "enabled": true,
      "labels": [
        {
          "name": "PHI",
          "tooltip": "Protected Health Information subject to HIPAA regulations",
          "color": "#D13438",
          "sublabels": [
            {
              "name": "Internal Clinical",
              "tooltip": "PHI for internal clinical use \u2014 no encryption applied",
              "encryption": false,
              "contentMarking": {
                "footerText": "Classification: PHI - Internal Clinical Use Only"
              }
            },
            {
              "name": "Restricted",
              "tooltip": "Encrypted PHI \u2014 restricted to authorized care team members",
              "encryption": true,
              "contentMarking": {
                "headerText": "PROTECTED HEALTH INFORMATION - Restricted",
                "footerText": "HIPAA: Do not distribute outside authorized care team"
              }
            }
          ]
        },
        {
          "name": "Research",
          "tooltip": "Clinical research data with varying levels of patient identifiability",
          "color": "#0078D4",
          "sublabels": [
            {
              "name": "De-identified",
              "tooltip": "Research data de-identified per HIPAA Safe Harbor method",
              "encryption": false,
              "contentMarking": {
                "footerText": "Research Data - De-identified per HIPAA Safe Harbor"
              }
            },
            {
              "name": "Identifiable",
              "tooltip": "Encrypted research data containing identifiable patient information",
              "encryption": true,
              "contentMarking": {
                "headerText": "RESEARCH - Contains Identifiable Patient Data",
                "footerText": "IRB approval required for access"
              }
            }
          ]
        }
      ],
      "autoLabelPolicies": [
        {
          "name": "Auto-label DEA Numbers as PHI Internal Clinical",
          "labelName": "PHI\\Internal Clinical",
          "sensitiveInfoTypes": [
            "Drug Enforcement Agency (DEA) Number"
          ],
          "locations": [
            "Exchange",
            "SharePoint"
          ]
        }
      ]
    },
    "retention": {
      "enabled": true,
      "policies": [
        {
          "name": "Medical Records Retention",
          "retentionDays": 2555,
          "retentionAction": "retainAndDelete",
          "locations": [
            "Exchange",
            "SharePoint"
          ]
        },
        {
          "name": "Patient Correspondence Hold",
          "retentionDays": 1095,
          "retentionAction": "retainOnly",
          "locations": [
            "Exchange",
            "OneDrive"
          ]
        }
      ]
    },
    "eDiscovery": {
      "enabled": true,
      "cases": [
        {
          "name": "Patient-Data-Breach-Investigation",
          "description": "Investigation into unauthorized access to patient medical records and PHI",
          "custodians": [
            "evasquez@MngEnvMCAP648165.onmicrosoft.com",
            "knakamura@MngEnvMCAP648165.onmicrosoft.com",
            "ayusuf@MngEnvMCAP648165.onmicrosoft.com",
            "nbennett@MngEnvMCAP648165.onmicrosoft.com"
          ],
          "holdQuery": "\"patient record\" OR \"medical history\" OR PHI",
          "searchQuery": "\"unauthorized access\" OR breach OR HIPAA"
        }
      ]
    },
    "communicationCompliance": {
      "enabled": true,
      "policies": [
        {
          "name": "Clinical Communication Monitoring",
          "reviewers": [
            "ldrummond@MngEnvMCAP648165.onmicrosoft.com",
            "nbennett@MngEnvMCAP648165.onmicrosoft.com"
          ],
          "supervisedUsers": [
            "spatel@MngEnvMCAP648165.onmicrosoft.com",
            "knakamura@MngEnvMCAP648165.onmicrosoft.com",
            "ayusuf@MngEnvMCAP648165.onmicrosoft.com"
          ],
          "direction": "Both",
          "condition": "offensive language"
        }
      ]
    },
    "insiderRisk": {
      "enabled": true,
      "policies": [
        {
          "name": "Departing Clinical Staff Data Theft",
          "template": "Data theft by departing users",
          "priorityUserGroups": [
            "PVMed-Clinical-Staff"
          ]
        }
      ]
    },
    "testData": {
      "enabled": true,
      "emails": [
        {
          "from": "knakamura",
          "to": "spatel",
          "subject": "Radiology Report - Patient John Doe",
          "body": "Dr. Patel, radiology results for patient John Doe (MRN: 4821957). CT scan of the abdomen shows a 2.3cm lesion in the left hepatic lobe, likely benign hemangioma. Recommend follow-up MRI in 6 months. Prescribing physician DEA number: AP5836727. Please review and update the patient chart."
        },
        {
          "from": "jwhitfield",
          "to": "evasquez",
          "subject": "Patient Discharge Summary",
          "body": "Emily, discharge summary for patient Maria Santos. SSN: 287-65-4319. Admitted 03/10 for acute appendicitis, underwent laparoscopic appendectomy. Discharge medications: Amoxicillin 500mg TID x 7 days, Hydrocodone 5/325mg PRN pain. Treating physician: Dr. Patel. Please file in the medical records system and ensure HIPAA compliance flags are set."
        },
        {
          "from": "spatel",
          "to": "rfeng",
          "subject": "Clinical Trial Data Transfer",
          "body": "Robert, we need to transfer the Phase II clinical trial dataset to the research partner at Metro University. The dataset includes 847 patient records with identifiers \u2014 names, DOBs, and treatment outcomes. IRB protocol #CT-2026-0142 covers this transfer but we need a signed BAA from Metro before proceeding. Can you coordinate with legal on the data sharing agreement?"
        },
        {
          "from": "ldrummond",
          "to": "spatel",
          "subject": "HIPAA Audit Finding - Potential PHI Exposure",
          "body": "Dr. Patel, during our quarterly HIPAA audit we identified unauthorized access to the EHR system. Between March 1-8, an account accessed 312 patient records outside normal workflow patterns. The access originated from the radiology department terminal. This constitutes a potential breach under HIPAA \u00a7164.402. We need to initiate the breach investigation protocol and assess whether patient notification is required under the 60-day rule. Please schedule a meeting with the incident response team this week."
        },
        {
          "from": "ayusuf",
          "to": "ldrummond",
          "subject": "Restricted PHI Transfer Review",
          "body": "Lisa, I need compliance review before transferring cardiology consult notes to an external specialist. The packet includes patient identifiers, treatment history, and insurance member ID 9XQ-441-772. Please confirm approved transmission controls and minimum necessary guidance."
        },
        {
          "from": "nbennett",
          "to": "spatel",
          "subject": "Employee Medical Leave File - HR Restricted",
          "body": "Dr. Patel, HR opened leave case ML-2026-204 for a surgical recovery request. Supporting documentation includes diagnosis notes, expected return date, and employee SSN 665-12-9044. Please provide return-to-work recommendations for the restricted HR record."
        }
      ]
    }
  },
  "cloud": "commercial"
}
