{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "title": "Purview Lab Deployer Configuration",
  "description": "Schema for Microsoft Purview lab deployment configurations",
  "type": "object",
  "required": [
    "labName",
    "prefix",
    "domain"
  ],
  "properties": {
    "labName": {
      "type": "string",
      "description": "Display name for the lab deployment"
    },
    "prefix": {
      "type": "string",
      "description": "Prefix applied to all resource names"
    },
    "domain": {
      "type": "string",
      "description": "Tenant domain (e.g., contoso.onmicrosoft.com)"
    },
    "cloud": {
      "type": "string",
      "description": "Cloud profile used for capability gating and path routing",
      "enum": [
        "commercial",
        "gcc"
      ]
    },
    "workloads": {
      "type": "object",
      "description": "Workload configurations to deploy",
      "properties": {
        "testUsers": {
          "type": "object",
          "properties": {
            "enabled": {
              "type": "boolean"
            },
            "mode": {
              "type": "string",
              "enum": [
                "create",
                "existing"
              ],
              "default": "create",
              "description": "User provisioning mode. 'create' provisions new users (default). 'existing' references pre-existing Entra ID users by UPN."
            },
            "users": {
              "type": "array",
              "items": {
                "oneOf": [
                  {
                    "type": "object",
                    "description": "User to create (mode=create)",
                    "required": [
                      "displayName",
                      "mailNickname",
                      "department",
                      "jobTitle",
                      "usageLocation"
                    ],
                    "properties": {
                      "displayName": {
                        "type": "string"
                      },
                      "mailNickname": {
                        "type": "string"
                      },
                      "department": {
                        "type": "string"
                      },
                      "jobTitle": {
                        "type": "string"
                      },
                      "usageLocation": {
                        "type": "string",
                        "minLength": 2,
                        "maxLength": 2
                      }
                    }
                  },
                  {
                    "type": "object",
                    "description": "Existing Entra ID user (mode=existing)",
                    "required": [
                      "upn"
                    ],
                    "properties": {
                      "upn": {
                        "type": "string",
                        "description": "User principal name of an existing Entra ID user"
                      }
                    },
                    "additionalProperties": false
                  }
                ]
              }
            },
            "groups": {
              "type": "array",
              "items": {
                "type": "object",
                "required": [
                  "displayName",
                  "members"
                ],
                "properties": {
                  "displayName": {
                    "type": "string"
                  },
                  "members": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    },
                    "description": "Array of mailNicknames (UPN local part before @)"
                  }
                }
              }
            }
          }
        },
        "dlp": {
          "type": "object",
          "properties": {
            "enabled": {
              "type": "boolean"
            },
            "simulationMode": {
              "type": "boolean",
              "description": "When true, all DLP policies deploy in simulation mode (TestWithNotifications) instead of active enforcement."
            },
            "policies": {
              "type": "array",
              "items": {
                "type": "object",
                "required": [
                  "name",
                  "locations",
                  "rules"
                ],
                "properties": {
                  "name": {
                    "type": "string"
                  },
                  "locations": {
                    "type": "array",
                    "items": {
                      "type": "string",
                      "enum": [
                        "Exchange",
                        "SharePoint",
                        "OneDrive",
                        "Teams",
                        "Devices",
                        "Copilot"
                      ]
                    }
                  },
                  "rules": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "required": [
                        "name",
                        "sensitiveInfoTypes",
                        "minCount"
                      ],
                      "properties": {
                        "name": {
                          "type": "string"
                        },
                        "sensitiveInfoTypes": {
                          "type": "array",
                          "items": {
                            "type": "string"
                          }
                        },
                        "minCount": {
                          "type": "integer",
                          "minimum": 1
                        },
                        "labels": {
                          "type": "array",
                          "items": {
                            "type": "string"
                          },
                          "description": "Optional sensitivity label conditions applied at rule level."
                        },
                        "enforcement": {
                          "type": "object",
                          "properties": {
                            "action": {
                              "type": "string",
                              "enum": [
                                "auditOnly",
                                "allowWithJustification",
                                "block"
                              ]
                            },
                            "userNotification": {
                              "type": "object",
                              "properties": {
                                "enabled": {
                                  "type": "boolean"
                                },
                                "message": {
                                  "type": "string"
                                }
                              }
                            },
                            "alert": {
                              "type": "object",
                              "properties": {
                                "enabled": {
                                  "type": "boolean"
                                },
                                "severity": {
                                  "type": "string",
                                  "enum": [
                                    "low",
                                    "medium",
                                    "high"
                                  ]
                                }
                              }
                            },
                            "incidentReport": {
                              "type": "object",
                              "properties": {
                                "enabled": {
                                  "type": "boolean"
                                },
                                "severity": {
                                  "type": "string",
                                  "enum": [
                                    "low",
                                    "medium",
                                    "high"
                                  ]
                                }
                              }
                            }
                          }
                        }
                      }
                    }
                  },
                  "policyMode": {
                    "type": "string",
                    "enum": [
                      "visibility",
                      "guardrail",
                      "highRiskBlock",
                      "labelRestriction",
                      "endpointExfil"
                    ],
                    "description": "Optional Shadow AI DLP policy intent classification."
                  },
                  "appliesToGroups": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    },
                    "description": "Optional group names/mailNicknames to scope policy enforcement."
                  },
                  "excludeGroups": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    },
                    "description": "Optional group names/mailNicknames excluded from enforcement."
                  },
                  "labels": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    },
                    "description": "Optional sensitivity label conditions for label-driven AI restrictions."
                  }
                }
              }
            }
          }
        },
        "sensitivityLabels": {
          "type": "object",
          "properties": {
            "enabled": {
              "type": "boolean"
            },
            "labels": {
              "type": "array",
              "items": {
                "type": "object",
                "required": [
                  "name",
                  "tooltip",
                  "color"
                ],
                "properties": {
                  "name": {
                    "type": "string"
                  },
                  "tooltip": {
                    "type": "string"
                  },
                  "color": {
                    "type": "string"
                  },
                  "sublabels": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "required": [
                        "name",
                        "tooltip"
                      ],
                      "properties": {
                        "name": {
                          "type": "string"
                        },
                        "tooltip": {
                          "type": "string"
                        },
                        "encryption": {
                          "type": "boolean"
                        },
                        "contentMarking": {
                          "type": "object",
                          "properties": {
                            "headerText": {
                              "type": "string"
                            },
                            "footerText": {
                              "type": "string"
                            }
                          }
                        }
                      }
                    }
                  }
                }
              }
            },
            "autoLabelPolicies": {
              "type": "array",
              "items": {
                "type": "object",
                "required": [
                  "name",
                  "labelName",
                  "sensitiveInfoTypes",
                  "locations"
                ],
                "properties": {
                  "name": {
                    "type": "string"
                  },
                  "labelName": {
                    "type": "string"
                  },
                  "sensitiveInfoTypes": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    }
                  },
                  "locations": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          }
        },
        "retention": {
          "type": "object",
          "properties": {
            "enabled": {
              "type": "boolean"
            },
            "policies": {
              "type": "array",
              "items": {
                "type": "object",
                "required": [
                  "name",
                  "retentionDays",
                  "retentionAction",
                  "locations"
                ],
                "properties": {
                  "name": {
                    "type": "string"
                  },
                  "retentionDays": {
                    "type": "integer",
                    "minimum": 1
                  },
                  "retentionAction": {
                    "type": "string",
                    "enum": [
                      "retainAndDelete",
                      "retainOnly"
                    ]
                  },
                  "locations": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          }
        },
        "eDiscovery": {
          "type": "object",
          "properties": {
            "enabled": {
              "type": "boolean"
            },
            "cases": {
              "type": "array",
              "items": {
                "type": "object",
                "required": [
                  "name",
                  "description"
                ],
                "properties": {
                  "name": {
                    "type": "string"
                  },
                  "description": {
                    "type": "string"
                  },
                  "custodians": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    },
                    "description": "Array of UPNs"
                  },
                  "holdQuery": {
                    "type": "string"
                  },
                  "searchQuery": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "communicationCompliance": {
          "type": "object",
          "properties": {
            "enabled": {
              "type": "boolean"
            },
            "policies": {
              "type": "array",
              "items": {
                "type": "object",
                "required": [
                  "name",
                  "reviewers",
                  "supervisedUsers",
                  "direction",
                  "condition"
                ],
                "properties": {
                  "name": {
                    "type": "string"
                  },
                  "reviewers": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    },
                    "description": "Array of UPNs"
                  },
                  "supervisedUsers": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    },
                    "description": "Array of UPNs"
                  },
                  "direction": {
                    "type": "string",
                    "enum": [
                      "Inbound",
                      "Outbound",
                      "Both"
                    ]
                  },
                  "condition": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "insiderRisk": {
          "type": "object",
          "properties": {
            "enabled": {
              "type": "boolean"
            },
            "policies": {
              "type": "array",
              "items": {
                "type": "object",
                "required": [
                  "name",
                  "template"
                ],
                "properties": {
                  "name": {
                    "type": "string"
                  },
                  "template": {
                    "type": "string"
                  },
                  "priorityUserGroups": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    },
                    "description": "Array of group display names"
                  }
                }
              }
            }
          }
        },
        "testData": {
          "type": "object",
          "properties": {
            "enabled": {
              "type": "boolean"
            },
            "emails": {
              "type": "array",
              "items": {
                "type": "object",
                "required": [
                  "from",
                  "to",
                  "subject",
                  "body"
                ],
                "properties": {
                  "from": {
                    "type": "string",
                    "description": "Sender mailNickname"
                  },
                  "to": {
                    "type": "string",
                    "description": "Recipient mailNickname"
                  },
                  "subject": {
                    "type": "string"
                  },
                  "body": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "appGovernance": {
          "type": "object",
          "description": "App Governance and Cloud Discovery configuration for AI app monitoring via MDCA REST API.",
          "properties": {
            "enabled": {
              "type": "boolean"
            },
            "aiApps": {
              "type": "array",
              "description": "AI apps to tag as unsanctioned in the MDCA cloud app catalog.",
              "items": {
                "type": "object",
                "required": [
                  "name"
                ],
                "properties": {
                  "name": {
                    "type": "string",
                    "description": "Display name of the AI app in the MDCA catalog."
                  },
                  "tag": {
                    "type": "string",
                    "enum": [
                      "unsanctioned",
                      "sanctioned",
                      "monitored"
                    ],
                    "default": "unsanctioned",
                    "description": "Tag to apply to the app."
                  }
                }
              }
            },
            "discoveryPolicies": {
              "type": "array",
              "description": "Cloud Discovery alert policies.",
              "items": {
                "type": "object",
                "required": [
                  "name"
                ],
                "properties": {
                  "name": {
                    "type": "string"
                  },
                  "category": {
                    "type": "string",
                    "description": "App category filter (e.g., Generative AI)."
                  },
                  "thresholdMb": {
                    "type": "integer",
                    "description": "Alert threshold in MB uploaded per day.",
                    "minimum": 1
                  },
                  "governanceAction": {
                    "type": "string",
                    "enum": [
                      "tag_unsanctioned",
                      "alert_only"
                    ],
                    "default": "tag_unsanctioned"
                  }
                }
              }
            },
            "sessionPolicies": {
              "type": "array",
              "description": "Session policies for real-time upload monitoring. Requires Conditional Access App Control.",
              "items": {
                "type": "object",
                "required": [
                  "name"
                ],
                "properties": {
                  "name": {
                    "type": "string"
                  },
                  "controlType": {
                    "type": "string",
                    "enum": [
                      "monitor",
                      "blockUpload",
                      "blockDownload"
                    ],
                    "default": "monitor"
                  },
                  "contentInspection": {
                    "type": "boolean",
                    "description": "Enable content inspection for sensitive info types.",
                    "default": false
                  }
                }
              }
            },
            "manualSteps": {
              "type": "array",
              "description": "Items that cannot be automated and require portal configuration.",
              "items": {
                "type": "object",
                "properties": {
                  "name": {
                    "type": "string"
                  },
                  "portal": {
                    "type": "string"
                  },
                  "instructions": {
                    "type": "string"
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}
