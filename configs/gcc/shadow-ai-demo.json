        {
          "name": "AI Incident Evidence Retention",
          "retentionDays": 1095,
          "retentionAction": "retainAndDelete",
          "locations": [
            "Exchange",
            "OneDrive"
          ]
        }
      ]
    },
    "eDiscovery": {
      "enabled": true,
      "cases": [
        {
          "name": "Shadow-AI-Incident-Review",
          "description": "Investigation into potential sensitive data exposure through unapproved AI tool usage.",
          "custodians": [
            "etran",
            "lramirez",
            "kmills"
          ],
          "holdQuery": "\"AI\" OR \"copilot\" OR \"chatbot\" OR \"prompt\"",
          "searchQuery": "\"public AI\" OR \"external AI\" OR \"paste\" OR \"upload\""
        }
      ]
    },
    "communicationCompliance": {
