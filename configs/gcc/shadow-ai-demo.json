    "customSensitiveInfoTypes": {
      "enabled": true,
      "types": [
        {
          "name": "Contoso Customer ID",
          "description": "Matches Contoso customer identifiers (CUST-XXXXXX format)",
          "pattern": "CUST-[0-9]{6}",
          "confidenceLevel": "High"
        },
        {
          "name": "API Key Pattern",
          "description": "Detects API keys and tokens (sk-/pk-/api_ prefixed strings)",
          "pattern": "(sk|pk|api)[-_][A-Za-z0-9]{20,}",
          "confidenceLevel": "High"
        },
        {
          "name": "Internal Project Code",
          "description": "Matches internal project codes (PRJ-XXXX format)",
          "pattern": "PRJ-[A-Z0-9]{4,8}",
          "confidenceLevel": "Medium"
        }
      ]
    },
    "dlp": {
      "enabled": true,
      "simulationMode": true,
      "policies": [
        {
          "name": "GenAI Prompt PII Protection",
          "locations": [
            "Devices"
          ],
          "rules": [
            {
              "name": "Detect SSNs in AI Prompts",
              "sensitiveInfoTypes": [
                "U.S. Social Security Number (SSN)"
              ],
              "minCount": 1,
              "enforcement": {
                "action": "auditOnly",
                "userNotification": {
                  "enabled": true,
                  "message": "Social Security Numbers detected in AI interaction. This data is monitored for compliance."
                },
                "alert": {
                  "enabled": true,
                  "severity": "low"
                }
              }
            },
            {
              "name": "Detect Credit Cards in AI Prompts",
              "sensitiveInfoTypes": [
                "Credit Card Number"
              ],
              "minCount": 1,
              "enforcement": {
                "action": "auditOnly",
                "userNotification": {
                  "enabled": true,
                  "message": "Credit card numbers detected in AI interaction. This data is monitored for compliance."
                },
                "alert": {
                  "enabled": true,
                  "severity": "low"
                }
              }
            }
          ],
          "policyMode": "visibility"
        },
        {
          "name": "GenAI Financial and Payroll Guardrail",
          "locations": [
            "Devices"
          ],
          "rules": [
            {
              "name": "Detect Bank Accounts in AI Content",
              "sensitiveInfoTypes": [
                "U.S. Bank Account Number"
              ],
              "minCount": 1,
              "enforcement": {
                "action": "allowWithJustification",
                "userNotification": {
                  "enabled": true,
                  "message": "You are sharing sensitive data with an AI destination. Provide a business justification to continue."
                },
                "alert": {
                  "enabled": true,
                  "severity": "medium"
                }
              }
            },
            {
              "name": "Detect SSNs in Payroll Discussions",
              "sensitiveInfoTypes": [
                "U.S. Social Security Number (SSN)"
              ],
              "minCount": 1,
              "enforcement": {
                "action": "allowWithJustification",
                "userNotification": {
                  "enabled": true,
                  "message": "You are sharing sensitive data with an AI destination. Provide a business justification to continue."
                },
                "alert": {
                  "enabled": true,
                  "severity": "medium"
                }
              }
            }
          ],
          "policyMode": "guardrail"
        },
        {
          "name": "External AI Upload Risk Signals",
          "locations": [
            "Copilot"
          ],
          "rules": [
            {
              "name": "Detect Medical Terms in AI Upload Attempts",
              "sensitiveInfoTypes": [
                "All Medical Terms And Conditions"
              ],
              "minCount": 1,
              "enforcement": {
                "action": "block",
                "userNotification": {
                  "enabled": true,
                  "message": "Medical data detected. Uploading protected health information to external AI tools violates policy."
                },
                "alert": {
                  "enabled": true,
                  "severity": "high"
                },
                "incidentReport": {
                  "enabled": true,
                  "severity": "high"
                }
              }
            },
            {
              "name": "Detect Credit Cards in External AI Sharing",
              "sensitiveInfoTypes": [
                "Credit Card Number"
              ],
              "minCount": 1,
              "enforcement": {
                "action": "block",
                "userNotification": {
                  "enabled": true,
                  "message": "Credit card data detected in external AI sharing. This action is blocked per data protection policy."
                },
                "alert": {
                  "enabled": true,
                  "severity": "high"
                },
                "incidentReport": {
                  "enabled": true,
                  "severity": "high"
                }
              }
            }
          ],
          "policyMode": "highRiskBlock",
          "appliesToGroups": [
            "PVShadowAI-Privileged-Data-Owners"
          ]
        },
        {
          "name": "Labeled Data AI Restriction",
          "policyMode": "labelRestriction",
          "locations": [
            "Copilot"
          ],
          "labels": [
            "PVShadowAI-Highly-Confidential-AI-Blocked-from-External-Tools",
            "PVShadowAI-Highly-Confidential-AI-Regulated-Data"
          ],
          "rules": [
            {
              "name": "Restrict Labeled Data in AI Destinations",
              "sensitiveInfoTypes": [
                "U.S. Social Security Number (SSN)"
              ],
              "minCount": 1,
              "labels": [
                "PVShadowAI-Highly-Confidential-AI-Blocked-from-External-Tools",
                "PVShadowAI-Highly-Confidential-AI-Regulated-Data"
              ],
              "enforcement": {
                "action": "block",
                "userNotification": {
                  "enabled": true,
                  "message": "This content has a sensitivity label that restricts AI usage. Use approved tools only."
                },
                "alert": {
                  "enabled": true,
                  "severity": "high"
                },
                "incidentReport": {
                  "enabled": true,
                  "severity": "high"
                }
              }
            }
          ]
        },
        {
          "name": "Endpoint AI Site Restrictions",
          "locations": [
            "Devices"
          ],
          "policyMode": "highRiskBlock",
          "endpointDlpBrowserRestrictions": {
            "blockedUrls": [
              "chat.openai.com",
              "chatgpt.com",
              "claude.ai",
              "gemini.google.com",
              "bard.google.com",
              "copilot.microsoft.com",
              "poe.com",
              "perplexity.ai",
              "huggingface.co/chat"
            ]
          },
          "rules": [
            {
              "name": "Block Sensitive Data Upload to AI Sites",
              "sensitiveInfoTypes": [
                "U.S. Social Security Number (SSN)",
                "Credit Card Number"
              ],
              "minCount": 1,
              "enforcement": {
                "action": "block",
                "userNotification": {
                  "enabled": true,
                  "message": "Uploading sensitive data to external AI tools is prohibited. Use Microsoft Copilot for AI-assisted tasks with organizational data protection."
                },
                "alert": {
                  "enabled": true,
                  "severity": "high"
                },
                "incidentReport": {
                  "enabled": true,
                  "severity": "high"
                }
              }
            }
          ]
        },
        {
          "name": "Adaptive AI Protection by Risk Level",
          "locations": [
            "Copilot"
          ],
          "policyMode": "adaptiveProtection",
          "rules": [
            {
              "name": "Block AI for Elevated Risk Users",
              "sensitiveInfoTypes": [
                "U.S. Social Security Number (SSN)",
                "Credit Card Number"
              ],
              "minCount": 1,
              "insiderRiskLevel": "Elevated",
              "enforcement": {
                "action": "block",
                "userNotification": {
                  "enabled": true,
                  "message": "Your access to AI tools is restricted due to elevated risk level. Contact your compliance team."
                },
                "alert": {
                  "enabled": true,
                  "severity": "high"
                },
                "incidentReport": {
                  "enabled": true,
                  "severity": "high"
                }
              }
            },
            {
              "name": "Warn AI for Moderate Risk Users",
              "sensitiveInfoTypes": [
                "U.S. Social Security Number (SSN)",
                "Credit Card Number"
              ],
              "minCount": 1,
              "insiderRiskLevel": "Moderate",
              "enforcement": {
                "action": "allowWithJustification",
                "userNotification": {
                  "enabled": true,
                  "message": "Moderate risk detected. Provide justification for sharing sensitive data with AI tools."
                },
                "alert": {
                  "enabled": true,
                  "severity": "medium"
                }
              }
            },
            {
              "name": "Audit AI for Minor Risk Users",
              "sensitiveInfoTypes": [
                "U.S. Social Security Number (SSN)"
              ],
              "minCount": 1,
              "insiderRiskLevel": "Minor",
              "enforcement": {
                "action": "auditOnly",
                "alert": {
                  "enabled": true,
                  "severity": "low"
                }
              }
            }
          ]
        }
      ]
    },
    "sensitivityLabels": {
      "enabled": true,
      "labels": [
        {
