    "dlp": {
      "enabled": true,
      "policies": [
        {
          "name": "US PII Protection",
          "locations": [
            "Exchange",
            "SharePoint",
            "OneDrive"
          ],
          "rules": [
            {
              "name": "Detect Social Security Numbers",
              "sensitiveInfoTypes": [
                "U.S. Social Security Number (SSN)"
              ],
              "minCount": 1
            },
            {
              "name": "Detect Credit Card Numbers",
              "sensitiveInfoTypes": [
                "Credit Card Number"
              ],
              "minCount": 1
            }
          ]
        },
        {
          "name": "Financial Data Protection",
          "locations": [
            "Exchange",
            "SharePoint",
            "Teams"
          ],
          "rules": [
            {
              "name": "Detect Bank Account Numbers",
              "sensitiveInfoTypes": [
                "U.S. Bank Account Number"
              ],
              "minCount": 1
            },
            {
              "name": "Detect Credit Cards in Financial Comms",
              "sensitiveInfoTypes": [
                "Credit Card Number"
              ],
              "minCount": 1
            }
          ]
        },
        {
          "name": "HR Case Data Protection",
          "locations": [
            "Exchange",
            "SharePoint",
            "OneDrive"
          ],
          "rules": [
            {
              "name": "Detect SSNs in HR Case Files",
              "sensitiveInfoTypes": [
                "U.S. Social Security Number (SSN)"
              ],
              "minCount": 1
            },
            {
              "name": "Detect Bank Account Data in HR Cases",
              "sensitiveInfoTypes": [
                "U.S. Bank Account Number"
              ],
              "minCount": 1
            }
          ]
        },
        {
          "name": "Workplace Health Record Protection",
          "locations": [
            "Exchange",
            "SharePoint",
            "Teams"
          ],
          "rules": [
            {
              "name": "Detect Medical Terms in Workplace Health Records",
              "sensitiveInfoTypes": [
                "All Medical Terms And Conditions"
              ],
              "minCount": 1
            },
            {
              "name": "Detect SSNs in Workplace Health Records",
              "sensitiveInfoTypes": [
                "U.S. Social Security Number (SSN)"
              ],
              "minCount": 1
            }
          ]
        }
      ]
    },
    "sensitivityLabels": {
      "enabled": true,
      "labels": [
