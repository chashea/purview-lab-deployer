    "dlp": {
      "enabled": true,
      "policies": [
        {
          "name": "US PII Protection",
          "locations": [
            "Exchange",
            "SharePoint",
            "OneDrive"
          ],
          "rules": [
            {
              "name": "Detect Social Security Numbers",
              "sensitiveInfoTypes": [
                "U.S. Social Security Number (SSN)"
              ],
              "minCount": 1,
              "enforcement": {
                "action": "block",
                "userNotification": {
                  "enabled": true,
                  "message": "This content matches a DLP policy. Contact your compliance team if you believe this is in error."
                },
                "alert": {
                  "enabled": true,
                  "severity": "medium"
                }
              }
            },
            {
              "name": "Detect Credit Card Numbers",
              "sensitiveInfoTypes": [
                "Credit Card Number"
              ],
              "minCount": 1,
              "enforcement": {
                "action": "block",
                "userNotification": {
                  "enabled": true,
                  "message": "This content matches a DLP policy. Contact your compliance team if you believe this is in error."
                },
                "alert": {
                  "enabled": true,
                  "severity": "medium"
                }
              }
            }
          ]
        },
        {
          "name": "Financial Data Protection",
          "locations": [
            "Exchange",
            "SharePoint",
            "OneDrive",
            "Teams"
          ],
          "rules": [
            {
              "name": "Detect Bank Account Numbers",
              "sensitiveInfoTypes": [
                "U.S. Bank Account Number"
              ],
              "minCount": 1,
              "enforcement": {
                "action": "block",
                "userNotification": {
                  "enabled": true,
                  "message": "This content matches a DLP policy. Contact your compliance team if you believe this is in error."
                },
                "alert": {
                  "enabled": true,
                  "severity": "medium"
                }
              }
            },
            {
              "name": "Detect Credit Cards in Financial Comms",
              "sensitiveInfoTypes": [
                "Credit Card Number"
              ],
              "minCount": 1,
              "enforcement": {
                "action": "block",
                "userNotification": {
                  "enabled": true,
                  "message": "This content matches a DLP policy. Contact your compliance team if you believe this is in error."
                },
                "alert": {
                  "enabled": true,
                  "severity": "medium"
                }
              }
            }
          ]
        },
        {
          "name": "HR Case Data Protection",
          "locations": [
            "Exchange",
            "SharePoint",
            "OneDrive"
          ],
          "rules": [
            {
              "name": "Detect SSNs in HR Case Files",
              "sensitiveInfoTypes": [
                "U.S. Social Security Number (SSN)"
