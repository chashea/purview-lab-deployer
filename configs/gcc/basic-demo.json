                "action": "block",
                "userNotification": {
                  "enabled": true,
                  "message": "This content matches a DLP policy. Contact your compliance team if you believe this is in error."
                },
                "alert": {
                  "enabled": true,
                  "severity": "medium"
                }
              }
            },
            {
              "name": "Detect Bank Account Data in HR Cases",
              "sensitiveInfoTypes": [
                "U.S. Bank Account Number"
              ],
              "minCount": 1,
              "enforcement": {
                "action": "block",
                "userNotification": {
                  "enabled": true,
                  "message": "This content matches a DLP policy. Contact your compliance team if you believe this is in error."
                },
                "alert": {
                  "enabled": true,
                  "severity": "medium"
                }
              }
            }
          ]
