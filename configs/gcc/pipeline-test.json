    "dlp": {
      "enabled": true,
      "policies": [
        {
          "name": "Pipeline-Test-SSN-v2",
          "locations": ["Exchange", "OneDrive"],
          "rules": [
            {
              "name": "Pipeline-Test-Detect-SSN-v2",
              "sensitiveInfoTypes": ["U.S. Social Security Number (SSN)"],
              "minCount": 1,
              "enforcement": {
                "action": "block",
                "userNotification": {
                  "enabled": true,
                  "message": "PIPELINE TEST: This message was blocked because it contains a U.S. Social Security Number. This is a deliberate DLP test."
                },
                "alert": {
                  "enabled": true,
                  "severity": "high"
                },
                "incidentReport": {
                  "enabled": true,
                  "severity": "high"
                }
              }
            }
          ]
        }
      ]
    }
  }
