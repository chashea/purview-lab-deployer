{
  "$schema": "./_schema.json",
  "labName": "Full Purview Demo",
  "prefix": "PVLab",
  "domain": "MngEnvMCAP648165.onmicrosoft.com",
  "workloads": {
    "testUsers": {
      "enabled": true,
      "users": [
        {
          "displayName": "Rachel Torres",
          "mailNickname": "rtorres",
          "department": "HR",
          "jobTitle": "HR Manager",
          "usageLocation": "US"
        },
        {
          "displayName": "Marcus Chen",
          "mailNickname": "mchen",
          "department": "Finance",
          "jobTitle": "Financial Analyst",
          "usageLocation": "US"
        },
        {
          "displayName": "Natalie Brooks",
          "mailNickname": "nbrooks",
          "department": "Legal",
          "jobTitle": "Legal Counsel",
          "usageLocation": "US"
        },
        {
          "displayName": "David Okafor",
          "mailNickname": "dokafor",
          "department": "IT",
          "jobTitle": "IT Security Engineer",
          "usageLocation": "US"
        },
        {
          "displayName": "Samantha Reeves",
          "mailNickname": "sreeves",
          "department": "Sales",
          "jobTitle": "Sales Director",
          "usageLocation": "US"
        },
        {
          "displayName": "Jonathan Blake",
          "mailNickname": "jblake",
          "department": "Executive",
          "jobTitle": "Chief Financial Officer",
          "usageLocation": "US"
        }
      ],
      "groups": [
        {
          "displayName": "PVLab-Executives",
          "members": ["jblake", "sreeves"]
        },
        {
          "displayName": "PVLab-Finance-Team",
          "members": ["mchen", "jblake"]
        },
        {
          "displayName": "PVLab-Legal-Team",
          "members": ["nbrooks", "rtorres"]
        }
      ]
    },
    "dlp": {
      "enabled": true,
      "policies": [
        {
          "name": "US PII Protection",
          "locations": ["Exchange", "SharePoint", "OneDrive"],
          "rules": [
            {
              "name": "Detect Social Security Numbers",
              "sensitiveInfoTypes": ["U.S. Social Security Number (SSN)"],
              "minCount": 1
            },
            {
              "name": "Detect Credit Card Numbers",
              "sensitiveInfoTypes": ["Credit Card Number"],
              "minCount": 1
            }
          ]
        },
        {
          "name": "Financial Data Protection",
          "locations": ["Exchange", "SharePoint", "Teams"],
          "rules": [
            {
              "name": "Detect Bank Account Numbers",
              "sensitiveInfoTypes": ["U.S. Bank Account Number"],
              "minCount": 1
            },
            {
              "name": "Detect Credit Cards in Financial Comms",
              "sensitiveInfoTypes": ["Credit Card Number"],
              "minCount": 1
            }
          ]
        }
      ]
    },
    "sensitivityLabels": {
      "enabled": true,
      "labels": [
        {
          "name": "Confidential",
          "tooltip": "Data that requires protection and is intended for internal use only",
          "color": "#0078D4",
          "sublabels": [
            {
              "name": "Internal Only",
              "tooltip": "For internal distribution — no encryption applied",
              "encryption": false,
              "contentMarking": {
                "footerText": "Classification: Confidential - Internal Only"
              }
            },
            {
              "name": "Recipients Only",
              "tooltip": "Encrypted — only designated recipients can access",
              "encryption": true,
              "contentMarking": {
                "headerText": "CONFIDENTIAL - Recipients Only",
                "footerText": "This document is encrypted and restricted to named recipients"
              }
            }
          ]
        },
        {
          "name": "Highly Confidential",
          "tooltip": "Highly sensitive data requiring strict access controls and encryption",
          "color": "#D13438",
          "sublabels": [
            {
              "name": "All Employees",
              "tooltip": "Encrypted — accessible to all employees within the organization",
              "encryption": true,
              "contentMarking": {
                "headerText": "HIGHLY CONFIDENTIAL - All Employees",
                "footerText": "Do not share outside the organization"
              }
            },
            {
              "name": "Specific People",
              "tooltip": "Encrypted — accessible only to specifically named individuals",
              "encryption": true,
              "contentMarking": {
                "headerText": "HIGHLY CONFIDENTIAL - Specific People",
                "footerText": "Restricted distribution — do not forward or copy"
              }
            }
          ]
        }
      ],
      "autoLabelPolicies": [
        {
          "name": "Auto-label SSN as Confidential Internal",
          "labelName": "Confidential\\Internal Only",
          "sensitiveInfoTypes": ["U.S. Social Security Number (SSN)"],
          "locations": ["Exchange", "SharePoint"]
        }
      ]
    },
    "retention": {
      "enabled": true,
      "policies": [
        {
          "name": "Financial Records Retention",
          "retentionDays": 2555,
          "retentionAction": "retainAndDelete",
          "locations": ["Exchange", "SharePoint"]
        },
        {
          "name": "Legal Hold Policy",
          "retentionDays": 365,
          "retentionAction": "retainOnly",
          "locations": ["Exchange", "OneDrive"]
        }
      ]
    },
    "eDiscovery": {
      "enabled": true,
      "cases": [
        {
          "name": "PVLab-Data-Breach-Investigation",
          "description": "Investigation into potential data breach involving unauthorized access to confidential financial records and PII",
          "custodians": [
            "mchen@MngEnvMCAP648165.onmicrosoft.com",
            "jblake@MngEnvMCAP648165.onmicrosoft.com"
          ],
          "holdQuery": "confidential OR classified",
          "searchQuery": "breach OR incident"
        }
      ]
    },
    "communicationCompliance": {
      "enabled": true,
      "policies": [
        {
          "name": "Offensive Language Monitoring",
          "reviewers": [
            "rtorres@MngEnvMCAP648165.onmicrosoft.com"
          ],
          "supervisedUsers": [
            "mchen@MngEnvMCAP648165.onmicrosoft.com",
            "sreeves@MngEnvMCAP648165.onmicrosoft.com"
          ],
          "direction": "Both",
          "condition": "offensive language"
        }
      ]
    },
    "insiderRisk": {
      "enabled": true,
      "policies": [
        {
          "name": "Departing User Data Theft",
          "template": "Data theft by departing users",
          "priorityUserGroups": ["PVLab-Executives"]
        }
      ]
    },
    "testData": {
      "enabled": true,
      "emails": [
        {
          "from": "mchen",
          "to": "jblake",
          "subject": "Q4 Financial Summary - Confidential",
          "body": "Hi Jonathan, attached is the Q4 financial summary. For reference, the wire transfer was initiated from account 0012345678 (routing 021000021). Please review before the board meeting. This information is strictly confidential."
        },
        {
          "from": "sreeves",
          "to": "mchen",
          "subject": "Client Payment Issue",
          "body": "Marcus, the client provided their credit card for the overdue invoice: 4111-1111-1111-1111, exp 12/27. Can you process this through the payment portal? Let me know if you need additional details."
        },
        {
          "from": "rtorres",
          "to": "nbrooks",
          "subject": "Employee Background Check Results",
          "body": "Natalie, here are the background check results for the new hire. SSN on file: 123-45-6789. Everything came back clean. Please file this with the other onboarding documents and mark as confidential."
        },
        {
          "from": "dokafor",
          "to": "jblake",
          "subject": "Suspicious Activity - Insider Trading Concern",
          "body": "Jonathan, I flagged unusual data access patterns from a departing employee. They downloaded several files related to the upcoming merger, including documents marked classified. This could indicate insider trading risk. We should initiate a breach investigation immediately."
        }
      ]
    }
  }
}
